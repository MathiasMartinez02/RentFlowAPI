# ─── Application ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=mysql://rentflow:rentflow_password@localhost:3306/rentflow
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_USER=rentflow
MYSQL_PASSWORD=rentflow_password
MYSQL_DB=rentflow
MYSQL_PORT=3306

# ─── JWT ──────────────────────────────────────────────────────
# Ambas claves deben tener al menos 32 caracteres para garantizar la seguridad de los tokens.
JWT_SECRET=your-access-token-secret-min-32-chars-change-in-prod
JWT_REFRESH_SECRET=your-refresh-token-secret-min-32-chars-change-in-prod
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d

# ─── Swagger ──────────────────────────────────────────────────
SWAGGER_ENABLED=true

# ─── Logging ──────────────────────────────────────────────────
LOG_LEVEL=debug

# ─── Admin ────────────────────────────────────────────────────
ADMINER_PORT=8080
