# ─── Application ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://rentflow:rentflow_password@localhost:5432/rentflow
POSTGRES_USER=rentflow
POSTGRES_PASSWORD=rentflow_password
POSTGRES_DB=rentflow
POSTGRES_PORT=5432

# ─── JWT ──────────────────────────────────────────────────────
# Must be at least 32 characters long
JWT_SECRET=your-super-secret-key-change-in-production-min-32-chars
JWT_EXPIRATION=7d

# ─── Swagger ──────────────────────────────────────────────────
SWAGGER_ENABLED=true

# ─── Logging ──────────────────────────────────────────────────
LOG_LEVEL=debug

# ─── Admin ────────────────────────────────────────────────────
ADMINER_PORT=8080
