# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database ───────────────────────────────────────────────────────────────
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=mysql://rentflow:rentflow_password@localhost:3306/rentflow

# ─── JWT ────────────────────────────────────────────────────────────────────
# Minimum 32 characters — use a random string in production
JWT_SECRET=change-me-to-a-random-32-char-secret!!
JWT_REFRESH_SECRET=change-me-to-another-random-32char-secret!
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d

# ─── Rate limiting ──────────────────────────────────────────────────────────
# General API limit: THROTTLE_LIMIT requests per THROTTLE_TTL seconds, per IP.
# /auth/login, /auth/register and /auth/refresh have an additional, stricter,
# hardcoded limit (5 requests/minute) — see src/modules/auth/auth.controller.ts.
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ─── CORS ───────────────────────────────────────────────────────────────────
# Use '*' for all origins (dev) or comma-separated list for production
# Example: http://localhost:3001,https://myapp.vercel.app
FRONTEND_URL=*

# ─── Swagger ────────────────────────────────────────────────────────────────
SWAGGER_ENABLED=true

# ─── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=debug

# ─── MySQL (used by docker-compose only) ────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_USER=rentflow
MYSQL_PASSWORD=rentflow_password
MYSQL_DB=rentflow
MYSQL_PORT=3306
ADMINER_PORT=8080
