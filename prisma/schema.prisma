generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  FINANZAS
  VENDEDOR
  MANTENIMIENTO
  CLIENTE
  INQUILINO
}

enum PropertyStatus {
  DISPONIBLE
  OCUPADA
  MANTENIMIENTO
}

enum PropertyType {
  APARTAMENTO
  DUPLEX
  CASA
  OFICINA
  LOCAL
}

enum TenantStatus {
  ACTIVO
  MOROSO
  INACTIVO
  PENDIENTE
}

enum ContractStatus {
  ACTIVO
  PROXIMO_A_VENCER
  VENCIDO
  CANCELADO
  RENOVADO
}

enum PaymentStatus {
  PENDIENTE
  PAGADO
  VENCIDO
  PARCIAL
  CANCELADO
}

enum PaymentMethod {
  TRANSFERENCIA
  EFECTIVO
  TARJETA
  DEBITO_AUTOMATICO
}

enum MaintenanceStatus {
  PENDIENTE
  EN_PROGRESO
  ESPERANDO_REPUESTOS
  RESUELTO
  CERRADO
}

enum MaintenancePriority {
  BAJA
  MEDIA
  ALTA
  URGENTE
}

enum MaintenanceCategory {
  PLOMERIA
  ELECTRICIDAD
  PINTURA
  LIMPIEZA
  SEGURIDAD
  GENERAL
}

enum NotificationType {
  PAYMENT
  CONTRACT
  MAINTENANCE
  SYSTEM
}

enum NotificationPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ─── Models ───────────────────────────────────────────────────

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  password    String
  nombre      String
  apellido    String
  empresa     String?
  phone       String?
  avatar      String?
  role           Role    @default(CLIENTE)
  organizationId String?
  linkedTenantId String? @unique
  isActive       Boolean  @default(true)
  ultimoLogin    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  linkedTenant         Tenant?       @relation("UserTenant", fields: [linkedTenantId], references: [id], onDelete: SetNull)
  refreshTokens        RefreshToken[]
  properties           Property[]
  tenants              Tenant[]
  contracts            Contract[]
  payments             Payment[]
  notifications        Notification[]
  maintenanceTickets   MaintenanceTicket[]
  activityLogs         ActivityLog[]

  @@map("users")
}

model RefreshToken {
  id          String   @id @default(cuid())
  hashedToken String   @unique @db.Char(64)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  revoked     Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

model Property {
  id              String         @id @default(cuid())
  nombre          String
  descripcion     String?        @db.Text
  direccion       String
  ciudad          String
  provincia       String
  codigoPostal    String
  pais            String         @default("Argentina")
  tipoPropiedad   PropertyType   @default(APARTAMENTO)
  estado          PropertyStatus @default(DISPONIBLE)
  precioMensual   Decimal        @db.Decimal(10, 2)
  expensas        Decimal?       @db.Decimal(10, 2)
  habitaciones    Int            @default(1)
  banos           Int            @default(1)
  metrosCuadrados Float
  imagenPrincipal String?
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  contracts          Contract[]
  maintenanceTickets MaintenanceTicket[]
  tenants            Tenant[]
  payments           Payment[]
  images             PropertyImage[]

  @@index([ownerId])
  @@index([estado])
  @@index([ciudad])
  @@index([tipoPropiedad])
  @@index([precioMensual])
  @@map("properties")
}

model Tenant {
  id              String       @id @default(cuid())
  nombre          String
  apellido        String
  email           String
  telefono        String
  dni             String
  fechaNacimiento DateTime?
  direccion       String?
  estado          TenantStatus @default(PENDIENTE)
  observaciones   String?      @db.Text
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  propertyId String?
  property   Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  contracts          Contract[]
  payments           Payment[]
  maintenanceTickets MaintenanceTicket[]
  linkedUser         User?              @relation("UserTenant")

  @@unique([email, ownerId])
  @@unique([dni, ownerId])
  @@index([ownerId])
  @@index([estado])
  @@index([propertyId])
  @@map("tenants")
}

model Contract {
  id                   String         @id @default(cuid())
  codigoContrato       String         @unique
  fechaInicio          DateTime
  fechaFin             DateTime
  montoMensual         Decimal        @db.Decimal(10, 2)
  deposito             Decimal        @db.Decimal(10, 2)
  expensas             Decimal?       @db.Decimal(10, 2)
  renovacionAutomatica Boolean        @default(false)
  estado               ContractStatus @default(ACTIVO)
  observaciones        String?        @db.Text
  isActive             Boolean        @default(true)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  payments Payment[]

  @@index([ownerId])
  @@index([propertyId])
  @@index([tenantId])
  @@index([estado])
  @@index([fechaFin])
  @@map("contracts")
}

model Payment {
  id              String         @id @default(cuid())
  periodo         String
  fechaVencimiento DateTime
  fechaPago       DateTime?
  monto           Decimal        @db.Decimal(10, 2)
  mora            Decimal?       @db.Decimal(10, 2)
  totalPagado     Decimal?       @db.Decimal(10, 2)
  metodoPago      PaymentMethod?
  referenciaPago  String?
  estado          PaymentStatus  @default(PENDIENTE)
  observaciones   String?        @db.Text
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  contractId String
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([contractId, periodo])
  @@index([ownerId])
  @@index([contractId])
  @@index([tenantId])
  @@index([propertyId])
  @@index([estado])
  @@index([fechaVencimiento])
  @@map("payments")
}

model MaintenanceTicket {
  id               String              @id @default(cuid())
  titulo           String
  descripcion      String              @db.Text
  categoria        MaintenanceCategory @default(GENERAL)
  prioridad        MaintenancePriority @default(MEDIA)
  estado           MaintenanceStatus   @default(PENDIENTE)
  costoEstimado    Decimal?            @db.Decimal(10, 2)
  costoFinal       Decimal?            @db.Decimal(10, 2)
  fechaResolucion  DateTime?
  assignedTo       String?
  observaciones    String?             @db.Text
  isActive         Boolean             @default(true)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([ownerId])
  @@index([propertyId])
  @@index([tenantId])
  @@index([estado])
  @@index([prioridad])
  @@index([categoria])
  @@map("maintenance_tickets")
}

model PropertyImage {
  id         String   @id @default(cuid())
  url        String
  filename   String
  mimeType   String
  size       Int
  createdAt  DateTime @default(now())

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@map("property_images")
}

model Notification {
  id        String               @id @default(cuid())
  titulo    String
  mensaje   String               @db.Text
  tipo      NotificationType     @default(SYSTEM)
  prioridad NotificationPriority @default(MEDIUM)
  leida     Boolean              @default(false)
  metadata  Json?
  createdAt DateTime             @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([leida])
  @@index([tipo])
  @@index([prioridad])
  @@map("notifications")
}

model ActivityLog {
  id          String   @id @default(cuid())
  action      String
  entityType  String
  entityId    String
  descripcion String
  metadata    Json?
  createdAt   DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entityType])
  @@index([action])
  @@map("activity_logs")
}
